{
  "name": "writing-ide",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "npm run -w @writing-ide/gateway dev",
    "dev:desktop": "npm run -w @writing-ide/desktop dev",
    "dev:admin": "npm run -w @writing-ide/admin-web dev",
    "build:desktop": "npm run -w @writing-ide/desktop build",
    "dist:desktop:win": "npm run -w @writing-ide/desktop dist:win",
    "dist:desktop:win:portable": "npm run -w @writing-ide/desktop dist:win:portable",
    "dist:desktop:win:all": "npm run -w @writing-ide/desktop dist:win:all"
  }
}


