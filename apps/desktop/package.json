{
  "name": "@writing-ide/desktop",
  "private": true,
  "version": "0.0.20",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm run -w @writing-ide/agent-core build && concurrently -n renderer,electron -c auto \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/dev-electron.cjs",
    "build": "npm run -w @writing-ide/agent-core build && vite build",
    "preview": "vite preview",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:win:portable": "npm run build && electron-builder --win portable --x64",
    "dist:win:all": "npm run build && electron-builder --win nsis portable --x64",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg zip --x64",
    "dist:mac:universal": "npm run build && electron-builder --mac dmg zip --universal"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@writing-ide/agent-core": "0.0.0",
    "mammoth": "^1.11.0",
    "monaco-editor": "^0.52.2",
    "pdf-parse": "^1.1.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "34.5.8",
    "electron-builder": "^24.13.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.writing-ide.desktop",
    "productName": "写作IDE",
    "directories": {
      "output": "out"
    },
    "asar": true,
    "npmRebuild": false,
    "files": [
      "**/*",
      "!src/**",
      "!**/*.map",
      "!**/*.md",
      "!**/.env*",
      "!**/writing-ide-data/**",
      "!**/node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
