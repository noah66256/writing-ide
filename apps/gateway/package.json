{
  "name": "@ohmycrab/gateway",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run -w @ohmycrab/kb-core build && npm run -w @ohmycrab/tools build && npm run -w @ohmycrab/agent-core build && tsx watch src/index.ts",
    "build": "npm run -w @ohmycrab/kb-core build && npm run -w @ohmycrab/tools build && npm run -w @ohmycrab/agent-core build && tsc -p tsconfig.json",
    "audit:ai": "tsx scripts/audit-ai-stages.ts",
    "regress:agent": "npm run -w @ohmycrab/agent-core build && tsx scripts/regress-agent-flow.ts",
    "smoke:endpoints": "npm run -w @ohmycrab/tools build && npm run -w @ohmycrab/agent-core build && tsx scripts/smoke-messages-responses.ts",
    "test:runner-turn": "tsx scripts/test-runner-turn.ts",
    "smoke:runtime-parity": "tsx scripts/smoke-runtime-parity.ts",
    "test:mcp-selection": "tsx scripts/validate-mcp-selection.ts",
    "smoke:mcp-server-first": "tsx scripts/smoke-mcp-server-first.ts",
    "smoke:workflow-sticky": "tsx scripts/smoke-workflow-sticky.ts",
    "smoke:mcp-session-reliability": "tsx scripts/smoke-mcp-session-reliability.ts"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "^2.0.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/websocket": "^10.0.1",
    "@mariozechner/pi-agent-core": "^0.56.3",
    "@mariozechner/pi-ai": "^0.56.3",
    "@ohmycrab/agent-core": "0.0.0",
    "@ohmycrab/kb-core": "0.0.0",
    "@ohmycrab/tools": "0.0.0",
    "dotenv": "^16.6.1",
    "fastify": "^4.29.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
