# 复制本文件为 .env（该文件已被 .gitignore 忽略，不会提交到仓库）
#
# 注意：不要把真实 key 发到聊天或提交到 git；建议用完即旋转/更换。

# ===== Gateway 基础 =====
PORT=8000
JWT_SECRET=dev-secret-change-me
# 多个管理员邮箱用英文逗号分隔（可选）
ADMIN_EMAILS=

# ===== 使用说明视频（临时对外分享链接）=====
# 路由：
# - /help/tutorial       播放页
# - /help/tutorial.mp4   mp4 流式（支持 Range，可拖动进度条）
# 默认会尝试读取项目根目录的 `1月26日.mp4`；生产建议显式配置为服务器绝对路径：
# TUTORIAL_VIDEO_PATH=/data/writing-ide/media/1月26日.mp4
# 可选：页面标题
# TUTORIAL_VIDEO_TITLE=写作IDE 使用说明
# 可选：缓存策略
# TUTORIAL_VIDEO_CACHE_CONTROL=public, max-age=3600

# ===== LLM（VectorEngine / OpenAI-compatible）=====
# OpenAI 兼容模式：不需要额外开关；按 OpenAI 协议调用：
# - /v1/chat/completions
# - /v1/models
#
# Provider Base URL（推荐不带 /v1）
LLM_BASE_URL=https://api.vectorengine.ai
# 默认模型（用于 Agent/对话）
LLM_MODEL=deepseek-v3
# 默认 API Key（用于 Agent/对话）：填你自己的（不要提交）
LLM_API_KEY=

# 可选：追加一个 OpenAI Responses 模型到「Chat/Agent 可选模型列表」
# - 用于在桌面端让用户直接切换（不会替换默认 LLM_MODEL）
# - 默认走 /v1/responses，baseURL 默认复用 LLM_BASE_URL
# LLM_OPENAI_MODEL=gpt-5.2
# LLM_OPENAI_BASE_URL=
# LLM_OPENAI_API_KEY=
# LLM_OPENAI_ENDPOINT=/v1/responses

# 可选：追加 Gemini 模型到「Chat/Agent 可选模型列表」
# - 默认 baseURL 为 `https://api.vectorengine.ai`
# - endpoint 直接填写 generateContent / streamGenerateContent 路径
# LLM_GEMINI_BASE_URL=https://api.vectorengine.ai
# LLM_GEMINI_API_KEY=
# LLM_GEMINI_PRO_MODEL=gemini-3.1-pro-preview
# LLM_GEMINI_PRO_ENDPOINT=/v1beta/models/gemini-3.1-pro-preview:generateContent
# LLM_GEMINI_FLASH_LITE_MODEL=gemini-3.1-flash-lite-preview
# LLM_GEMINI_FLASH_LITE_ENDPOINT=/v1beta/models/gemini-3.1-flash-lite-preview:generateContent

# 抽卡专用（可选）：如果抽卡要用不同模型/不同 key，就填下面两项（否则会回退到默认 LLM_*）
LLM_CARD_MODEL=gpt-5.2
LLM_CARD_API_KEY=
# 若抽卡走不同 Base URL，可选填（默认复用 LLM_BASE_URL）
# LLM_CARD_BASE_URL=

# 抽卡自动重试（429/上游繁忙）：指数退避（默认 3 次，800ms 起步）
# LLM_CARD_RETRY_MAX=3
# LLM_CARD_RETRY_BASE_MS=800
#
# 抽卡/风格手册超时（ms）：避免上游卡住导致 Desktop 侧长时间等待后变成“fetch failed”
# LLM_CARD_TIMEOUT_MS=120000

# ===== Embeddings（向量检索/重排，用于 KB 检索 A/B 测试）=====
# 说明：
# - Base URL 通常与 LLM_BASE_URL 相同（OpenAI-compatible）
# - API Key：你要求与抽卡一致（可直接复用 LLM_CARD_API_KEY）
# - 模型：支持同时配置多个，便于 A/B（例如 text-embedding-3-large vs Embedding-V1）
#
# Embedding Base URL（可选，默认复用 LLM_BASE_URL）
# LLM_EMBED_BASE_URL=
# Embedding API Key（可选，默认回退到 LLM_CARD_API_KEY，再回退到 LLM_API_KEY）
# LLM_EMBED_API_KEY=
# Embedding 模型列表（逗号分隔，第一项作为默认）
LLM_EMBED_MODELS=text-embedding-3-large,Embedding-V1

# ===== Style Linter（强模型风格对齐：终稿闸门）=====
# 说明：
# - 用于“绑定风格库 + 写作类任务”时的终稿验收：先 kb.search 拉样例 → 产出候选稿 → lint.style 对齐检查 → 通过才写入
# - 默认优先复用抽卡配置（LLM_CARD_*）；如需单独覆盖再配置 LLM_LINTER_*
# - 用户可在指令里说“跳过linter/不要风格检查”来临时跳过（仍会强制 kb.search 拉样例）
#
# LLM_LINTER_MODEL=gpt-5
# LLM_LINTER_API_KEY=
# LLM_LINTER_BASE_URL=
# LLM_LINTER_TIMEOUT_MS=60000
#
# 通过门槛（默认 80 分，且 high issue=0）
STYLE_LINT_PASS_SCORE=80
# 最大回炉次数（默认 2；超过会提示用户是否“跳过linter”强制输出）
STYLE_LINT_MAX_REWORK=2
# 防贴原文回炉次数（lint.copy；默认 2；与 “跳过linter” 同进退）
STYLE_COPY_LINT_MAX_REWORK=2
# lint.copy 模式：
# - off：不启用（不强制、不 gate）
# - observe：默认（不作为硬闸门；可手动调用 lint.copy 但不会因未调用而卡住）
# - gate：作为闸门强制执行（未通过则回炉/降级）
STYLE_COPY_LINT_MODE=observe

# ===== Tool Calls Repair（工具 XML/参数 修复器，可选但强烈建议）=====
# 目的：当模型输出工具调用时偶发出现：
# - XML 解析失败（tool_xml_parse_failed）
# - 或工具参数不符合 schema（tool_args_invalid）
# 网关会（可选）先调用一个“小模型”把输出修成严格的 <tool_calls> XML，再走白名单+schema 校验。
# 注意：这只是“格式/参数修复器”，不是决策器；最终仍会经过校验，不通过就丢弃并回退到让主模型重试。
#
# 开关：默认关闭（0）。建议你在服务器部署一个 1.5B~3B 的 OpenAI-compatible 小模型后开启。
TOOL_CALL_REPAIR_ENABLED=0
#
# 小模型配置（可选）
# - 若不填：会回退复用 LLM_BASE_URL/LLM_API_KEY（以及默认模型）
# - 若你自建本地/内网小模型（OpenAI-compatible），建议单独填 BASE_URL + MODEL（API_KEY 可为空或随便填）
#
# LLM_TOOL_REPAIR_BASE_URL=http://127.0.0.1:8001
# LLM_TOOL_REPAIR_MODEL=qwen2.5-1.5b-instruct
# LLM_TOOL_REPAIR_API_KEY=

# ===== Context Pack Selector（上下文注入选择器：用 1.5B 小模型挑选要注入的上下文，可选）=====
# 目的：
# - 让“短回复 + 上下文承接”（例如“话题3吧/选3”）更稳，不容易被 router 判 unclear
# - 在预算内挑选最相关的上下文段落，减少噪音与 token 成本
#
# 开关：默认关闭（0）。建议你在服务器部署 1.5B 小模型后开启。
CONTEXT_SELECTOR_ENABLED=0
#
# 模式：
# - off：关闭
# - router_only：只用于 Intent Router 的输入提示（优先推荐先灰度这个）
# - agent_only：只用于主 Agent 的 context 裁剪（进阶）
# - all：两者都用
CONTEXT_SELECTOR_MODE=router_only
#
# 超时（ms）：必须短，避免拖慢主链路
# CONTEXT_SELECTOR_TIMEOUT_MS=2000
#
# 小模型配置（可选）
# - 若不填：会回退复用 LLM_TOOL_REPAIR_*（再回退 LLM_*）
# LLM_CONTEXT_SELECTOR_BASE_URL=http://127.0.0.1:8001
# LLM_CONTEXT_SELECTOR_MODEL=qwen2.5-1.5b-instruct
# LLM_CONTEXT_SELECTOR_API_KEY=

# ===== Web Search（联网检索 + 抓正文证据，v0.1 默认使用博查 Bocha）=====
# 说明：
# - Chat 模式仅暴露 web.search/web.fetch（只读联网）；Agent/Plan 也可用
# - Gateway 侧工具默认允许列表包含 web.search/web.fetch；如需强制收敛可设置 GATEWAY_SERVER_TOOL_ALLOWLIST
#
# 博查 API Key（必填；不要提交到 git）
# BOCHA_API_KEY=
# 可选：自定义 Web Search endpoint（默认 https://api.bochaai.com/v1/web-search）
# BOCHA_WEB_SEARCH_ENDPOINT=
#
# 域名治理（可选，逗号分隔；支持 example.com / *.example.com）
# - allow 非空：只允许匹配域名
# - deny 优先生效：命中则拒绝
# WEB_ALLOW_DOMAINS=
# WEB_DENY_DOMAINS=
#
# 抓取 UA（可选）
# WEB_FETCH_UA=

# ===== SMS Verify（手机号验证码登录：阿里云 号码认证服务 Dypnsapi）=====
# 说明：
# - 建议优先通过 B 端 Tools -> SMS Verify 配置（会加密存入 data/db.json，热生效）
# - 这里提供 env 兜底（B 端未配置时使用）
#
# 访问密钥（任选其一组变量名）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# 或（兼容 SDK 习惯）
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
#
# 可选：服务接入点（默认 dypnsapi.aliyuncs.com；可填 https://dypnsapi.aliyuncs.com）
# ALIYUN_DYPNSAPI_ENDPOINT=
# 可选：方案名称（不填=默认方案）
# ALIYUN_DYPNSAPI_SCHEME_NAME=
#

# ===== 微信支付（充值买积分：仅通道B - 公众号 H5(JSAPI) 收银台）=====
#
# 说明：
# - Desktop 会创建充值订单并生成二维码/链接：PAY_BASE_URL + /pay/:token
# - 用户用手机微信打开该链接完成支付（JSAPI）；支付结果由微信回调到 WX_NOTIFY_URL
# - 回调验签推荐用“微信支付公钥”（见下方 WX_PAY_PLATFORM_PUBLIC_KEY_*）
#
# 开关：开发可先 false；联调/生产必须 true
WX_PAY_ENABLED=false
# 回调验签严格模式（建议生产 true；开发可 false）
WX_PAY_VERIFY_STRICT=false
#
# 商户号
WX_MCH_ID=
# API v3 密钥（32字节）
WX_API_V3_KEY=
# 商户 API 证书序列号（40位十六进制）
WX_SERIAL_NO=
# 商户 API 私钥（完整 PEM 或去头尾后的单行 base64）
WX_PRIVATE_KEY=
#
# 支付回调（必须是 HTTPS，且需公网可达）
# 对应本项目路由：POST /api/payments/wxpay/notify
WX_NOTIFY_URL=https://api.yourdomain.com/api/payments/wxpay/notify
#
# 公众号网页授权（用于 H5(JSAPI) 收银台获取 openid）
WX_MP_APP_ID=
WX_MP_APP_SECRET=
#
# 收银台域名（建议独立域名指向本 Gateway；必须与公众号后台配置的网页授权域名一致）
PAY_BASE_URL=https://pay.yourdomain.com
#
# 微信支付公钥（推荐验签方式）
# - 在微信商户平台 -> API 安全 申请“微信支付公钥”
WX_PAY_PLATFORM_PUBLIC_KEY_ID=
WX_PAY_PLATFORM_PUBLIC_KEY=
# 必填（生产）：赠送签名 + 赠送模板（需在号码认证控制台配置）
# ALIYUN_DYPNSAPI_SIGN_NAME=速通互联验证码
# ALIYUN_DYPNSAPI_TEMPLATE_CODE=100001

