# 复制本文件为 .env（该文件已被 .gitignore 忽略，不会提交到仓库）
#
# 注意：不要把真实 key 发到聊天或提交到 git；建议用完即旋转/更换。

# ===== Gateway 基础 =====
PORT=8000
JWT_SECRET=dev-secret-change-me
# 多个管理员邮箱用英文逗号分隔（可选）
ADMIN_EMAILS=

# ===== LLM（VectorEngine / OpenAI-compatible）=====
# Provider Base URL（由你提供）
LLM_BASE_URL=https://api.vectorengine.ai
# 模型名（由你提供）
LLM_MODEL=deepseek-v3.2
# API Key：填你自己的（不要提交）
LLM_API_KEY=


