# 复制本文件为 .env（该文件已被 .gitignore 忽略，不会提交到仓库）
#
# 注意：不要把真实 key 发到聊天或提交到 git；建议用完即旋转/更换。

# ===== Gateway 基础 =====
PORT=8000
JWT_SECRET=dev-secret-change-me
# 多个管理员邮箱用英文逗号分隔（可选）
ADMIN_EMAILS=

# ===== LLM（VectorEngine / OpenAI-compatible）=====
# OpenAI 兼容模式：不需要额外开关；按 OpenAI 协议调用：
# - /v1/chat/completions
# - /v1/models
#
# Provider Base URL（推荐不带 /v1）
LLM_BASE_URL=https://api.vectorengine.ai
# 默认模型（用于 Agent/对话）
LLM_MODEL=deepseek-v3
# 默认 API Key（用于 Agent/对话）：填你自己的（不要提交）
LLM_API_KEY=

# 抽卡专用（可选）：如果抽卡要用不同模型/不同 key，就填下面两项（否则会回退到默认 LLM_*）
LLM_CARD_MODEL=gpt-5.2
LLM_CARD_API_KEY=
# 若抽卡走不同 Base URL，可选填（默认复用 LLM_BASE_URL）
# LLM_CARD_BASE_URL=

# 抽卡自动重试（429/上游繁忙）：指数退避（默认 3 次，800ms 起步）
# LLM_CARD_RETRY_MAX=3
# LLM_CARD_RETRY_BASE_MS=800
#
# 抽卡/风格手册超时（ms）：避免上游卡住导致 Desktop 侧长时间等待后变成“fetch failed”
# LLM_CARD_TIMEOUT_MS=120000

# ===== Embeddings（向量检索/重排，用于 KB 检索 A/B 测试）=====
# 说明：
# - Base URL 通常与 LLM_BASE_URL 相同（OpenAI-compatible）
# - API Key：你要求与抽卡一致（可直接复用 LLM_CARD_API_KEY）
# - 模型：支持同时配置多个，便于 A/B（例如 text-embedding-3-large vs Embedding-V1）
#
# Embedding Base URL（可选，默认复用 LLM_BASE_URL）
# LLM_EMBED_BASE_URL=
# Embedding API Key（可选，默认回退到 LLM_CARD_API_KEY，再回退到 LLM_API_KEY）
# LLM_EMBED_API_KEY=
# Embedding 模型列表（逗号分隔，第一项作为默认）
LLM_EMBED_MODELS=text-embedding-3-large,Embedding-V1

# ===== Style Linter（强模型风格对齐：终稿闸门）=====
# 说明：
# - 用于“绑定风格库 + 写作类任务”时的终稿验收：先 kb.search 拉样例 → 产出候选稿 → lint.style 对齐检查 → 通过才写入
# - 默认优先复用抽卡配置（LLM_CARD_*）；如需单独覆盖再配置 LLM_LINTER_*
# - 用户可在指令里说“跳过linter/不要风格检查”来临时跳过（仍会强制 kb.search 拉样例）
#
# LLM_LINTER_MODEL=gpt-5
# LLM_LINTER_API_KEY=
# LLM_LINTER_BASE_URL=
# LLM_LINTER_TIMEOUT_MS=60000
#
# 通过门槛（默认 80 分，且 high issue=0）
STYLE_LINT_PASS_SCORE=80
# 最大回炉次数（默认 2；超过会提示用户是否“跳过linter”强制输出）
STYLE_LINT_MAX_REWORK=2


